# Runtime
LLM_PROVIDER=siliconflow
RUN_MODE=real
LLM_TIMEOUT_SECONDS=45

# OpenAI, optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# SiliconFlow, optional OpenAI-compatible relay
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V4-Flash
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# DeepSeek official API, optional OpenAI-compatible provider
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Anthropic, optional
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# GitHub, optional
GITHUB_TOKEN=

# Feishu custom bot, optional
FEISHU_WEBHOOK_URL=

# DingTalk custom robot, optional
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# Local deployment
STREAMLIT_SERVER_PORT=8501
