[Unit]
Description=Digital Employee Daily Report Streamlit App
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/digital_employee_daily_report
ExecStart=/home/ubuntu/digital_employee_daily_report/.venv/bin/streamlit run app.py --server.port 8501 --server.address 0.0.0.0
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
